# Environment variables for {{projectName}}
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored and must
# never be committed. Keep this `.env.example` in sync: every variable the app reads
# should appear here with a safe placeholder, and be documented in
# .docs/environment.md.
#
# Vite only exposes variables prefixed with VITE_ to client code (import.meta.env).
# Anything without that prefix stays server-side only and is never bundled.

# Example: public app title exposed to the frontend
VITE_APP_TITLE={{projectName}}

# Example: base URL of your API (uncomment and set as needed)
# VITE_API_BASE_URL=http://localhost:3000
